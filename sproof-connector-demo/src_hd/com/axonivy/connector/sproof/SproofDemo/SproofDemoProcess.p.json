      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Prepare signature request.",
      "config" : {
        "output" : {
          "code" : [
            "import com.sproof.sign.api.v1.client.Recipient;",
            "import com.sproof.sign.api.v1.client.SignaturePosition;",
            "import com.sproof.sign.api.v1.client.DocumentRecipientDetails;",
            "import com.axonivy.connector.sproof.client.DocumentSignerDetails;",
            "import com.sproof.sign.api.v1.client.Signer;",
            "import com.axonivy.connector.sproof.service.SproofDemoService;",
            "import com.sproof.sign.api.v1.client.Document;",
            "import com.axonivy.connector.sproof.service.SproofService;",
            "",
            "SproofService sproof = SproofService.get();",
            "",
            "in.createSignatureRequest = sproof.createCreateSignatureRequest();",
            "",
            "Document document = sproof.createDocumentData(in.fileName, in.fileContent);",
            "",
            "in.createSignatureRequest.getEnvelopeData()",
            "  .setUsePlaceholders(in.usePlaceholders)",
            "  .addDocumentDataArrayItem(document);",
            "",
            "if(!in.usePlaceholders) {",
            "  List signers = SproofDemoService.get().createSigners(",
            "    in.signer1Email, in.signer1FirstName, in.signer1LastName,",
            "    in.signer2Email, in.signer2FirstName, in.signer2LastName);",
            "",
            "  ivy.log.info(\"Signers: {0}\", signers.size());",
            "",
            "  Number y = 0.6;",
            "",
            "  for(Signer signer : signers) {",
            "    in.createSignatureRequest.inviteData.addRecipientsItem(new Recipient().email(signer.email).firstName(signer.firstName).lastName(signer.lastName));",
            "    DocumentSignerDetails sd = new DocumentSignerDetails();",
            "    sd.addSignaturePosition(new SignaturePosition().page(0).x(0.3).y(y).width(0.3).height(0.1));",
            "    document.putRecipientDetailsItem(signer.email, sd);",
            "    y += 0.2;",
            "  }",
            "}",
            "",
            "SproofDemoService.get().check(in.createSignatureRequest);"
          ]
        }
      },
      "visual" : {
