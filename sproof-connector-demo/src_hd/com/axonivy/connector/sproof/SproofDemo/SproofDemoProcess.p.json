      "id" : "f23",
      "type" : "RestClientCall",
      "name" : "Get document info",
      "config" : {
        "target" : {
          "clientId" : "d39c224c-a0d6-48f7-aa80-4203da324cef",
          "path" : "/documents/{memberId}",
          "templateParams" : {
            "memberId" : "in.memberId"
          },
          "queryParams" : {
            "token" : "com.axonivy.connector.sproof.service.SproofService.get().getApiToken()"
          }
        },
        "response" : {
          "entity" : {
            "type" : "com.sproof.sign.api.v1.client.SproofDocument",
            "map" : {
              "out.fileName" : "result.name + \".pdf\""
            },
            "code" : [
              "import com.sproof.sign.api.v1.client.SproofMember;",
              "import com.sproof.sign.api.v1.client.MemberResponseSchema;",
              "import java.util.Iterator;",
              "import java.io.PrintWriter;",
              "import java.io.StringWriter;",
              "",
              "StringWriter sw = new StringWriter();",
              "PrintWriter pw = new PrintWriter(sw);",
              "",
              "pw.println(\"Status of request %s:\".formatted(result.name));",
              "pw.println(\"Signing round: %s\".formatted(result.signingRound));",
              "pw.println(\"All members signed: %s\".formatted(result.allMembersSigned));",
              "",
              "Iterator it = result.members.iterator();",
              "",
              "while(it.hasNext()) {",
              "  SproofMember member = it.next() as SproofMember;",
              "  pw.println(\"Member: %s signed at: %s (declined at: %s)\".formatted(member.#email, member.#signedAt, member.#declinedAt));",
              "",
              "}",
              "",
              "",
              "in.out = sw.toString();"
            ]
          }
        }
      },
