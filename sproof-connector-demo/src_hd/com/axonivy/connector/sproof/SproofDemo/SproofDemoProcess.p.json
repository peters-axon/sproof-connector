      "type" : "RestClientCall",
      "name" : "Create signature request.",
      "config" : {
        "method" : "POST",
        "target" : {
          "clientId" : "d39c224c-a0d6-48f7-aa80-4203da324cef",
          "path" : "/documents/signature"
        },
        "body" : {
          "entity" : {
            "type" : "com.sproof.sign.api.v1.client.CreateSignatureRequest",
            "map" : {
              "param" : "in.createSignatureRequest"
            }
          }
        },
        "response" : {
